# Aura Chat Template — Environment Variables
# Copy this file to .env.local and fill in your values

# OpenAI API Configuration (if using OpenAI)
# Get your API key from https://platform.openai.com/account/api-keys
VITE_OPENAI_API_KEY=

# Anthropic Claude API Configuration (if using Anthropic)
# Get your API key from https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=

# Backend API Base URL
# For local development or your own backend
VITE_API_BASE_URL=http://localhost:5000

# Note: Browser-side API keys are visible to users.
# For production, proxy requests through your own backend server
# and keep API keys server-side only.
