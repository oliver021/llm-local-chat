# llm-local-chat — Environment Variables
# Copy this file to .env.local and fill in your values

# llama.cpp server URL
# Used by the Vite dev proxy (dev) and nginx (Docker).
# Default port for llama-server is 8080.
VITE_LLAMA_SERVER_URL=http://localhost:8080

# Docker: set MODEL_FILE to the filename of your GGUF model inside ./models/
# Default is model.gguf — rename your file or set this variable.
# MODEL_FILE=mistral-7b-q4_k_m.gguf

# OpenAI API key (future provider)
VITE_OPENAI_API_KEY=

# Anthropic Claude API key (future provider)
VITE_ANTHROPIC_API_KEY=

# Note: Browser-side API keys are visible to users.
# For production, proxy requests through your own backend server
# and keep API keys server-side only.
